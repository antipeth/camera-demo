<div class="flex flex-col items-center justify-center space-y-6">


  <!-- 视频播放元素 -->
  <div class="w-full max-w-2xl bg-gray-800 p-4 rounded-lg shadow-lg">
    <video
      id="videoElement"
      width="100%"
      height="auto"
      autoPlay
      playsInline
      style="display: none; border-radius: 8px;"
    />
  </div>
  <!-- 摄像头开关按钮 -->
  <button
  id="toggleButton"
  class="px-6 py-3 bg-teal-600 text-white rounded-md hover:bg-teal-500 transition duration-300"
>
    开启摄像头
  </button>
</div>

<script>
  let hasPermission = false;
  let stream = null;

  // 获取 DOM 元素
  const videoElement = document.getElementById('videoElement');
  const toggleButton = document.getElementById('toggleButton');

  const startVideo = async () => {
    try {
      // 请求摄像头权限
      stream = await navigator.mediaDevices.getUserMedia({ video: true });
      hasPermission = true;
      videoElement.srcObject = stream;
      videoElement.style.display = 'block';  // 显示 video 元素
      toggleButton.textContent = '关闭摄像头';  // 更新按钮文本
    } catch (err) {
      console.error('Error accessing webcam:', err);
      hasPermission = false;
    }
  };

  const stopVideo = () => {
    if (stream) {
      const tracks = stream.getTracks();
      tracks.forEach(track => track.stop());
      stream = null;
      hasPermission = false;
      videoElement.srcObject = null;
      videoElement.style.display = 'none';  // 隐藏 video 元素
      toggleButton.textContent = '开启摄像头';  // 恢复按钮文本
    }
  };

  // 为按钮添加事件监听
  toggleButton.addEventListener('click', () => {
    if (hasPermission) {
      stopVideo();
    } else {
      startVideo();
    }
  });
</script>
